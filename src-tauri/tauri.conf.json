{
  "productName": "Wan2.2 Video Generator",
  "version": "0.1.3",
  "identifier": "com.wan2p2.videogenerator",
  "build": {
    "beforeDevCommand": "echo 'Dev mode'",
    "beforeBuildCommand": "echo 'Building'",
    "frontendDist": "frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Wan2.2 Video Generator",
        "label": "main",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/"
    ],
    "windows": {
      "wix": {
        "upgradeCode": "3C3E9F4A-8B7D-4E2A-9F1C-6D5E8A7B9C4D"
      }
    }
  }
}
