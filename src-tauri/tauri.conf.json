{
  "productName": "Wan2.2 Video Generator",
  "version": "0.1.0",
  "identifier": "com.wan2p2.videogenerator",
  "build": {
    "beforeDevCommand": "echo 'Dev mode'",
    "beforeBuildCommand": "echo 'Building'",
    "devUrl": "http://localhost:7860",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wan2.2 Video Generator",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "focus": true,
        "url": "http://localhost:7860"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
